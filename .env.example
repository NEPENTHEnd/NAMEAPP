# ============================================================================
# Name Teknik — Ortam Değişkenleri (örnek)
#
# Bu dosyayı KOPYALA -> .env.local olarak kaydet ve kendi Supabase
# projenin değerleriyle doldur. .env.local repoya GİTMEZ (gizli kalır).
# Değerleri Supabase panelinde: Project Settings > API bölümünden alırsın.
# ============================================================================

# Supabase proje URL'i (Project Settings > API > Project URL)
# Tarayıcıya da gönderilir, bu yüzden NEXT_PUBLIC_ ön ekli.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Public "anon" anahtarı (Project Settings > API > anon public)
# Sadece public anahtardır; RLS sayesinde güvenlidir, tarayıcıya gider.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role anahtarı (Project Settings > API > service_role secret)
# DİKKAT: Tüm RLS'i atlar. Yalnızca sunucu tarafı script'lerde (örn. Excel
# veri taşıma) kullanılır. ASLA tarayıcıya gönderme, NEXT_PUBLIC_ yapma.
# Şimdilik gerekmez; veri taşıma adımında kullanılacak.
SUPABASE_SERVICE_ROLE_KEY=
