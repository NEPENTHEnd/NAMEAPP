# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ama örnek dosya repoda kalsın (içinde gizli değer yok)
!.env.example

# içe aktarma çıktıları (çıkarılan fotoğraflar / temiz veri)
/scripts/_cikti
# Claude Design handoff klasörleri (referans, repoya gerek yok)
/Name Teknik Servis Takip-handoff*
/MART_2026.xlsx
/~$*.xlsx
# python
__pycache__/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
